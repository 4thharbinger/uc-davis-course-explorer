model Course {
  id          String   @id @default(cuid()) // Unique string ID
  code        String   @unique              
  name        String                        
  units       Int

  prerequisites Json
  
  instructors Instructor[] 
}

model Instructor {
  id          String   @id @default(cuid())
  fullName    String                        
  department  String                        
  rmpScore    Float?                        
  
  courses     Course[] 
}