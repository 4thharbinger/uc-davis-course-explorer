// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Course {
  id          String   @id @default(cuid()) // Unique string ID
  slug        String   @unique              // Unique slug for URLs with no special characters (eg. MAT021A)
  code        String   @unique              // Unique course code as it shows up in the catalog (eg. MAT 021A)
  description String
  shortDesc   String?
  name        String
  grading     String
  
  units       String
  learningActivities   Json?
  generalEducation     Json?
  
  prerequisiteRules Json
  rawPrerequisitesText String?

  prerequisites     Course[] @relation("PrerequisiteGraph")
  prerequisiteFor   Course[] @relation("PrerequisiteGraph")
  
  instructors Instructor[] 
  sections    Section[]
  
  examCredits ExamCredit[]
}

model Instructor {
  id          String   @id @default(cuid())
  fullName    String   @unique                     
  department  String?                       
  email       String?                 
  rmpScore    Float?                        
  
  courses     Course[] 
  sections    Section[]
}

model Section {
  crn          String   @id // e.g., "36077"
  courseCode   String       // Links to Course.code (e.g., "MAT021C")
  termCode     String       // e.g., "202610" (Fall 2026)
  sectionNum   String       // e.g., "A01"
  instructors  Instructor[]      // e.g., "Garving Luli"
  
  meetings     Json         @default("[]") 
  finalExam    DateTime?
  
  course       Course   @relation(fields: [courseCode], references: [slug], onDelete: Cascade)
}

model School {
  name String @id
  fullName String
  shortName String
  address String
}

model Exam {
  @@id([type, subject, level])

  type        String // e.g., ib, ap, placement
  subject     String // e.g., physics
  level       String // e.g., hl
  name        String // e.g., IB Physics HL

  examCredits ExamCredit[]
}

model ExamCredit {
  id String @id @default(cuid())

  @@unique([school, examType, examSubject, examLevel, minScore])

  school String
  creditUnits Int
  examType     String
  examSubject  String
  examLevel    String

  minScore    Int 
  maxScore    Int @default(999999)

  duplicateCredit Boolean @default(false)
  
  exam Exam @relation(fields: [examType, examSubject, examLevel], references: [type, subject, level])

  creditCourses Course[]
}

model Degree {
  @@id([school, code])

  school       String // e.g., ucdavis
  code         String // e.g., EASE
  requirements Json   
}

// public visible user stuff
model UserProfile { 
  username     String @id
  display      String?
  email        String?

  user          User         @relation(fields: [username], references: [username], map: "user_profile_username_fkey")
}

// private user data
model UserData { 
  username     String @id
  exams        Json //  array of IB/AP/Placement Exams
  courses      Json //  array of all courses taken by user

  user         User         @relation(fields: [username], references: [username], map: "user_data_username_fkey")
}

// login info
model User {
  username     String @id
  password     String // hashed password
  created      DateTime @default(now())
  lastActive   DateTime @updatedAt
  
  profile      UserProfile?
  data         UserData?
}