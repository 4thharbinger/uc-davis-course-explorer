// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Course {
  id          String   @id @default(cuid()) // Unique string ID
  slug        String   @unique              // Unique slug for URLs with no special characters (eg. MAT021A)
  code        String   @unique              // Unique course code as it shows up in the catalog (eg. MAT 021A)
  description String
  shortDesc   String?
  name        String
  grading     String
  
  units       String
  learningActivities   Json?
  generalEducation     Json?
  
  prerequisiteRules Json
  rawPrerequisitesText String?

  prerequisites     Course[] @relation("PrerequisiteGraph")
  prerequisiteFor   Course[] @relation("PrerequisiteGraph")
  
  instructors Instructor[] 
  sections    Section[]
}

model Instructor {
  id          String   @id @default(cuid())
  fullName    String                        
  department  String                        
  rmpScore    Float?                        
  
  courses     Course[] 
}

model Section {
  crn          String   @id // e.g., "36077"
  courseCode   String       // Links to Course.code (e.g., "MAT 021C")
  termCode     String       // e.g., "202610" (Fall 2026)
  sectionNum   String       // e.g., "A01"
  instructor   String?      // e.g., "Garving Luli"
  
  meetings     Json         @default("[]") 
  
  course       Course   @relation(fields: [courseCode], references: [code], onDelete: Cascade)
}